"attempt_count", "time_spent",
"fast_and_wrong", "long_and_wrong",
"struggle_no_help", "fast_multiple_attempts",
"easy_correct",
"session_progress"
)
library(dplyr)
# Combine x and y for sampling
train_bal = train_clean %>%
mutate(bored = as.factor(bored))
# Split classes
bored_1 = train_bal %>% filter(bored == 1)
bored_0 = train_bal %>% filter(bored == 0)
# Downsample majority class
set.seed(42)
bored_0_down = bored_0 %>% sample_n(nrow(bored_1))
# Combine balanced dataset
train_balanced = bind_rows(bored_1, bored_0_down)
# Split back
xtrain_bal = train_balanced %>% select(-bored)
ytrain_bal = train_balanced$bored
set.seed(42)
m.rf = randomForest(
x = xtrain,
y = ytrain,
ntree = 300,
mtry = 3,
importance = TRUE
)
#######################################
#######################################
#######################################
####### BEGIN INPUT: Question 5 #######
#######################################
library(ROCR)
# TRAIN AUC
train_probs = predict(m.rf, xtrain_bal, type="prob")[,2]
pred_train = prediction(train_probs, ytrain_bal)
perf_AUC = performance(pred_train, "auc")
AUC = perf_AUC@y.values[[1]]
cat("Training AUC:", round(AUC, 4), "\n")
# TEST AUC
test_probs = predict(m.rf, xtest, type="prob")[,2]
pred_test = prediction(test_probs, ytest)
perf_AUC_test = performance(pred_test, "auc")
AUC_test = perf_AUC_test@y.values[[1]]
cat("Test AUC:", round(AUC_test, 4), "\n")
#######################################
#######################################
#######################################
####### BEGIN INPUT: Question 3 #######
#######################################
features = c(
"correct", "ms_first_response", "hint_count",
"attempt_count", "time_spent",
"fast_and_wrong", "long_and_wrong",
"struggle_no_help", "fast_multiple_attempts",
"easy_correct",
"session_progress"
)
library(dplyr)
# Combine x and y for sampling
train_bal = train_clean %>%
mutate(bored = as.factor(bored))
# Split classes
bored_1 = train_bal %>% filter(bored == 1)
bored_0 = train_bal %>% filter(bored == 0)
# Downsample majority class
set.seed(42)
bored_0_down = bored_0 %>% sample_n(nrow(bored_1))
# Combine balanced dataset
train_balanced = bind_rows(bored_1, bored_0_down)
# Split back
xtrain_bal = train_balanced %>% select(-bored)
ytrain_bal = train_balanced$bored
set.seed(42)
m.rf = randomForest(
x = xtrain,
y = ytrain,
ntree = 300,
mtry = 3,
importance = TRUE,
classwt = c(1, 3)
)
#######################################
#######################################
#######################################
####### BEGIN INPUT: Question 5 #######
#######################################
library(ROCR)
# TRAIN AUC
train_probs = predict(m.rf, xtrain_bal, type="prob")[,2]
pred_train = prediction(train_probs, ytrain_bal)
perf_AUC = performance(pred_train, "auc")
AUC = perf_AUC@y.values[[1]]
cat("Training AUC:", round(AUC, 4), "\n")
# TEST AUC
test_probs = predict(m.rf, xtest, type="prob")[,2]
pred_test = prediction(test_probs, ytest)
perf_AUC_test = performance(pred_test, "auc")
AUC_test = perf_AUC_test@y.values[[1]]
cat("Test AUC:", round(AUC_test, 4), "\n")
