# =====================
instructor_dash = tabItem(
tabName = "instructor",
h2("Instructor Dashboard"),
fluidRow(
infoBoxOutput("inst.total_students"),
infoBoxOutput("inst.avg_attendance"),
infoBoxOutput("inst.avg_score"),
infoBoxOutput("inst.avg_sentiment")
),
fluidRow(
box(title = "Quiz Score Trend", width = 6,
plotOutput("inst.quiz_trend", height = 250)),
box(title = "Attendance Rate by Quiz", width = 6,
plotOutput("inst.attendance_rate", height = 250))
),
fluidRow(
box(title = "Score Distribution by Program", width = 6,
plotOutput("inst.score_dist", height = 250)),
box(title = "Prior Skill vs Quiz Performance", width = 6,
plotOutput("inst.skill_vs_score", height = 250))
)
)
# =====================
# STUDENT DASHBOARD
# =====================
student_dash = tabItem(
tabName = "student",
h2("Student Dashboard"),
fluidRow(
infoBoxOutput("stu.attendance"),
infoBoxOutput("stu.avg_score"),
infoBoxOutput("stu.clicker_acc"),
infoBoxOutput("stu.sentiment")
),
fluidRow(
box(title = "My Quiz Scores vs Class Average", width = 6,
plotOutput("stu.quiz_compare", height = 250)),
box(title = "My Attendance per Session", width = 6,
plotOutput("stu.attendance_plot", height = 250))
),
fluidRow(
box(title = "My Sentiment vs Class Average", width = 6,
plotOutput("stu.sentiment_plot", height = 250)),
box(title = "My Prior Skill Profile", width = 6,
plotOutput("stu.skills", height = 250))
)
)
#######################################
#######################################
library(tidyverse)
# Below you are loading 2 new packages:shiny + shinydashboard.
# Install them once, then comment out the install command.
# install.packages("shiny")
library(shiny)
# install.packages("shinydashboard")
library(shinydashboard)
# This should load the datasets:
# experience (123 by 11) and quiz (2423 by 13)
load("info4100.proj.dashboard.rda")
#######################################
####### BEGIN INPUT: Question 4 #######
#######################################
# Sample Data
attendance_data <- data.frame(
session = factor(paste0("S", 1:12), levels = paste0("S", 1:12)),
status = c("attended", "attended", "attended", "absent",
"attended", "attended", "attended", "absent",
"attended", "attended", "attended", "attended")
)
attendance_data$height <- ifelse(attendance_data$status == "attended", 1.0, 0.5)
ui <- fluidPage(
tags$style(HTML("
body { background-color: #1a1a1a; color: white; font-family: 'Inter', sans-serif; }
.attendance-card {
background-color: #2b2b2b;
padding: 30px;
border-radius: 20px;
width: 550px;
margin: 50px auto;
}
.card-title { font-size: 24px; font-weight: bold; margin-bottom: 5px; }
.card-subtitle { font-size: 16px; color: #aaaaaa; margin-bottom: 40px; }
")),
div(class = "attendance-card",
div(class = "card-title", "My attendance per session"),
div(class = "card-subtitle",
HTML("<span style='color:#56ae7c;'>Green</span> = attended · <span style='color:#b55347;'>Red</span> = absent")),
plotOutput("attendancePlot", height = "200px")
)
)
server <- function(input, output) {
output$attendancePlot <- renderPlot({
ggplot(attendance_data, aes(x = session, y = height, fill = status)) +
# Draw the bars
geom_col(width = 0.6, show.legend = FALSE, linewidth = 0) +
# Set colors
scale_fill_manual(values = c("attended" = "#56ae7c", "absent" = "#b55347")) +
# Theme
scale_y_continuous(limits = c(0, 1.1), expand = c(0, 0)) +
theme_void() +
theme(
panel.background = element_rect(fill = "transparent", colour = NA),
plot.background = element_rect(fill = "transparent", colour = NA),
axis.text.x = element_text(color = "#888888", size = 11, margin = margin(t = 10)),
plot.margin = margin(0, 10, 0, 10)
) +
# X axis label.
scale_y_continuous(expand = expansion(mult = c(0, 0.1)))
}, bg = "transparent")
}
shinyApp(ui, server)
