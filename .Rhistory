library(tidyverse)
# Below you are loading 2 new packages:shiny + shinydashboard.
# Install them once, then comment out the install command.
# install.packages("shiny")
library(shiny)
# install.packages("shinydashboard")
library(shinydashboard)
# This should load the datasets:
# experience (123 by 11) and quiz (2423 by 13)
load("info4100.proj.dashboard.rda")
#######################################
####### BEGIN INPUT: Question 3 #######
#######################################
# Example of a tab (i.e. page)
instructor_dash = tabItem(
tabName = "instructor",
h2("Instructor Dashboard"),
# Dynamic infoBoxes
fluidRow(
infoBoxOutput("inst.info1"),
infoBoxOutput("inst.info2"),
infoBoxOutput("inst.info3")
),
# Filter controls (new instructor feature support)
fluidRow(
box(
title = "Instructor Filters",
width = 12,
selectInput("inst.year", "Select year", choices = c("All"), selected = "All"),
sliderInput("inst.attend_cutoff", "Risk attendance cutoff (%)",
min = 40, max = 95, value = 75, step = 5),
sliderInput("inst.quiz_cutoff", "Risk avg quiz cutoff (out of 20)",
min = 8, max = 18, value = 14, step = 1)
)
),
# Visualizations
fluidRow(
box(
title = "Quiz Score Distribution",
plotOutput("inst.plot1", height = 250)
),
box(
title = "Clicker Completion Distribution",
plotOutput("inst.plot2", height = 250)
)
),
fluidRow(
box(
title = "Average Quiz Score by Quiz Number",
plotOutput("inst.plot3", height = 250)
),
box(
title = "Attendance Trend by Session",
plotOutput("inst.plot4", height = 250)
)
),
# New instructor feature: at-risk student list
fluidRow(
box(
title = "Student Intervention Map",
width = 12,
plotOutput("inst.risk.map", height = 300)
)
),
fluidRow(
box(
title = "At-Risk Students (filtered by year)",
width = 12,
tableOutput("inst.risk.table")
)
)
)
# Another empty tab
student_dash = tabItem(
tabName = "student",
h2("Student Dashboard"),
fluidRow(
box(
title = "Student Selection",
width = 12,
selectInput("stud.key", "Select student", choices = c())
)
),
fluidRow(
infoBoxOutput("stud.info1"),
infoBoxOutput("stud.info2"),
infoBoxOutput("stud.info3")
),
fluidRow(
box(
title = "Quiz Scores Over Time",
plotOutput("stud.plot1", height = 250)
),
box(
title = "Clicker Completion Over Time",
plotOutput("stud.plot2", height = 250)
)
),
fluidRow(
box(
title = "Student vs Class Quiz Performance",
plotOutput("stud.plot3", height = 250)
),
box(
title = "Attendance by Session",
plotOutput("stud.plot4", height = 250)
)
)
)
#######################################
#######################################
#######################################
####### BEGIN INPUT             #######
#######################################
# Keep a clean copy and derive helper variables used by UI/server outputs
quiz_clean = quiz %>%
mutate(
clicker_completion_rate = if_else(
TOTAL_POSSIBLE_CLICKER > 0,
TOTAL_COMPLETED_CLICKER / TOTAL_POSSIBLE_CLICKER,
NA_real_
)
)
experience_clean = experience
# Shared selectors
inst_year_choices = c("All", sort(unique(quiz_clean$YEAR)))
student_choices = sort(unique(quiz_clean$STUDENT_KEY))
reference_student_key = student_choices[1]
# Instructor-level summaries
instructor_overview = quiz_clean %>%
summarise(
students_total = n_distinct(STUDENT_KEY),
attendance_rate = mean(ATTENDED, na.rm = TRUE),
avg_quiz_score = mean(QUIZ_SCORE, na.rm = TRUE)
)
instructor_quiz_summary = quiz_clean %>%
group_by(YEAR, QUIZ_NUMBER) %>%
summarise(
avg_quiz_score = mean(QUIZ_SCORE, na.rm = TRUE),
avg_attendance = mean(ATTENDED, na.rm = TRUE),
.groups = "drop"
)
instructor_session_summary = quiz_clean %>%
group_by(YEAR, SESSION_NUMBER) %>%
summarise(
attendance_rate = mean(ATTENDED, na.rm = TRUE),
avg_clicker_completion = mean(clicker_completion_rate, na.rm = TRUE),
.groups = "drop"
)
# New instructor feature data: students needing intervention
# Rule: attendance < 75% OR average quiz score < 14
instructor_at_risk = quiz_clean %>%
group_by(YEAR, STUDENT_KEY) %>%
summarise(
attendance_rate = mean(ATTENDED, na.rm = TRUE),
avg_quiz_score = mean(QUIZ_SCORE, na.rm = TRUE),
sessions = n(),
.groups = "drop"
) %>%
mutate(
risk_flag = attendance_rate < 0.75 | avg_quiz_score < 14
) %>%
filter(risk_flag) %>%
arrange(YEAR, attendance_rate, avg_quiz_score)
# Student-level summaries for selected/Reference student views
student_session_data = quiz_clean %>%
filter(STUDENT_KEY == reference_student_key) %>%
arrange(SESSION_NUMBER)
student_quiz_comparison = quiz_clean %>%
group_by(QUIZ_NUMBER) %>%
summarise(
class_avg_quiz = mean(QUIZ_SCORE, na.rm = TRUE),
reference_student_avg = mean(
QUIZ_SCORE[STUDENT_KEY == reference_student_key],
na.rm = TRUE
),
.groups = "drop"
)
#######################################
#######################################
server = function(input, output) {
#######################################
####### BEGIN INPUT: Question 4 #######
#######################################
updateSelectInput(session, "inst.year",
choices = inst_year_choices,
selected = "All")
updateSelectInput(session, "stud.key",
choices = student_choices,
selected = reference_student_key)
instructor_filtered = reactive({
req(input$inst.year)
if (input$inst.year == "All") {
quiz_clean
} else {
quiz_clean %>% filter(YEAR == as.numeric(input$inst.year))
}
})
instructor_student_rollup = reactive({
req(input$inst.year)
filtered = if (input$inst.year == "All") {
quiz_clean
} else {
quiz_clean %>% filter(YEAR == as.numeric(input$inst.year))
}
filtered %>%
group_by(STUDENT_KEY) %>%
summarise(
attendance_rate = mean(ATTENDED, na.rm = TRUE),
avg_quiz_score = mean(QUIZ_SCORE, na.rm = TRUE),
sessions = n(),
.groups = "drop"
)
})
at_risk_filtered = reactive({
req(input$inst.attend_cutoff, input$inst.quiz_cutoff)
instructor_student_rollup() %>%
mutate(
risk_status = case_when(
attendance_rate < input$inst.attend_cutoff / 100 &
avg_quiz_score < input$inst.quiz_cutoff ~ "Low attendance + low score",
attendance_rate < input$inst.attend_cutoff / 100 ~ "Low attendance",
avg_quiz_score < input$inst.quiz_cutoff ~ "Low score",
TRUE ~ "On track"
)
) %>%
filter(risk_status != "On track") %>%
arrange(attendance_rate, avg_quiz_score)
})
student_data = reactive({
req(input$stud.key)
quiz_clean %>%
filter(STUDENT_KEY == as.numeric(input$stud.key)) %>%
arrange(SESSION_NUMBER)
})
output$inst.info1 = renderInfoBox({
infoBox("Students total",
n_distinct(instructor_filtered()$STUDENT_KEY),
icon = icon("users"), color = "purple")
})
output$inst.info2 = renderInfoBox({
infoBox("Attendance",
paste0(round(100 * mean(instructor_filtered()$ATTENDED, na.rm = TRUE), 1), "%"),
icon = icon("calendar-check"), color = "yellow")
})
output$inst.info3 = renderInfoBox({
infoBox("Avg Quiz Score",
round(mean(instructor_filtered()$QUIZ_SCORE, na.rm = TRUE), 2),
icon = icon("pen"), color = "teal")
})
output$inst.plot1 = renderPlot({
ggplot(instructor_filtered(), aes(x = QUIZ_SCORE)) +
geom_histogram(binwidth = 1, fill = "#2c7fb8", color = "white") +
labs(x = "Quiz Score", y = "Count") +
theme_classic()
})
output$inst.plot2 = renderPlot({
ggplot(instructor_filtered(), aes(x = TOTAL_COMPLETED_CLICKER)) +
geom_density(fill = "gray80") +
labs(x = "Completed Clicker Questions", y = "Density") +
theme_classic()
})
output$inst.plot3 = renderPlot({
quiz_by_quiz = instructor_filtered() %>%
group_by(QUIZ_NUMBER) %>%
summarise(avg_quiz_score = mean(QUIZ_SCORE, na.rm = TRUE), .groups = "drop")
ggplot(quiz_by_quiz, aes(x = QUIZ_NUMBER, y = avg_quiz_score)) +
geom_line(color = "#1f78b4", linewidth = 1) +
geom_point(color = "#1f78b4", size = 2) +
scale_x_continuous(breaks = sort(unique(quiz_by_quiz$QUIZ_NUMBER))) +
labs(x = "Quiz Number", y = "Average Quiz Score") +
theme_classic()
})
output$inst.plot4 = renderPlot({
attend_by_session = instructor_filtered() %>%
group_by(SESSION_NUMBER) %>%
summarise(attendance_rate = mean(ATTENDED, na.rm = TRUE), .groups = "drop")
ggplot(attend_by_session, aes(x = SESSION_NUMBER, y = attendance_rate)) +
geom_line(color = "#33a02c", linewidth = 1) +
geom_point(color = "#33a02c", size = 1.8) +
scale_y_continuous(labels = scales::percent_format(accuracy = 1)) +
labs(x = "Session Number", y = "Attendance Rate") +
theme_classic()
})
output$inst.risk.map = renderPlot({
req(input$inst.attend_cutoff, input$inst.quiz_cutoff)
map_df = instructor_student_rollup() %>%
mutate(
risk_status = case_when(
attendance_rate < input$inst.attend_cutoff / 100 &
avg_quiz_score < input$inst.quiz_cutoff ~ "Low attendance + low score",
attendance_rate < input$inst.attend_cutoff / 100 ~ "Low attendance",
avg_quiz_score < input$inst.quiz_cutoff ~ "Low score",
TRUE ~ "On track"
)
)
ggplot(map_df, aes(x = 100 * attendance_rate, y = avg_quiz_score, color = risk_status)) +
geom_point(alpha = 0.8, size = 2.8) +
geom_vline(xintercept = input$inst.attend_cutoff, linetype = "dashed", color = "gray40") +
geom_hline(yintercept = input$inst.quiz_cutoff, linetype = "dashed", color = "gray40") +
scale_color_manual(values = c(
"Low attendance + low score" = "#de2d26",
"Low attendance" = "#fc9272",
"Low score" = "#fdae6b",
"On track" = "#bdbdbd"
)) +
labs(
x = "Attendance Rate (%)",
y = "Average Quiz Score (out of 20)",
color = "Status"
) +
theme_classic()
})
output$inst.risk.table = renderTable({
at_risk_filtered() %>%
transmute(
student_key = STUDENT_KEY,
attendance_percent = round(100 * attendance_rate, 1),
avg_quiz_score = round(avg_quiz_score, 2),
sessions = sessions,
status = risk_status
)
})
output$stud.info1 = renderInfoBox({
infoBox("Student attendance",
paste0(round(100 * mean(student_data()$ATTENDED, na.rm = TRUE), 1), "%"),
icon = icon("user-check"), color = "aqua")
})
output$stud.info2 = renderInfoBox({
infoBox("Student avg quiz score",
round(mean(student_data()$QUIZ_SCORE, na.rm = TRUE), 2),
icon = icon("chart-line"), color = "green")
})
output$stud.info3 = renderInfoBox({
infoBox("Student avg clicker completion",
round(mean(student_data()$TOTAL_COMPLETED_CLICKER, na.rm = TRUE), 2),
icon = icon("mouse-pointer"), color = "orange")
})
output$stud.plot1 = renderPlot({
student_quiz = student_data() %>%
group_by(QUIZ_NUMBER) %>%
summarise(avg_quiz_score = mean(QUIZ_SCORE, na.rm = TRUE), .groups = "drop")
ggplot(student_quiz, aes(x = QUIZ_NUMBER, y = avg_quiz_score)) +
geom_col(fill = "#3182bd") +
scale_x_continuous(breaks = sort(unique(student_quiz$QUIZ_NUMBER))) +
labs(x = "Quiz Number", y = "Student Quiz Score") +
theme_classic()
})
output$stud.plot2 = renderPlot({
ggplot(student_data(), aes(x = SESSION_NUMBER, y = TOTAL_COMPLETED_CLICKER)) +
geom_line(color = "#756bb1", linewidth = 1) +
geom_point(color = "#756bb1", size = 1.8) +
labs(x = "Session Number", y = "Completed Clicker Questions") +
theme_classic()
})
output$stud.plot3 = renderPlot({
student_quiz = student_data() %>%
group_by(QUIZ_NUMBER) %>%
summarise(student_avg = mean(QUIZ_SCORE, na.rm = TRUE), .groups = "drop")
class_quiz = quiz_clean %>%
group_by(QUIZ_NUMBER) %>%
summarise(class_avg = mean(QUIZ_SCORE, na.rm = TRUE), .groups = "drop")
compare_df = left_join(student_quiz, class_quiz, by = "QUIZ_NUMBER")
compare_long = compare_df %>%
pivot_longer(cols = c(student_avg, class_avg),
names_to = "group",
values_to = "score")
ggplot(compare_long, aes(x = QUIZ_NUMBER, y = score, color = group)) +
geom_line(linewidth = 1) +
geom_point(size = 2) +
scale_color_manual(values = c(student_avg = "#d95f0e", class_avg = "#2b8cbe"),
labels = c(student_avg = "Student", class_avg = "Class")) +
labs(x = "Quiz Number", y = "Average Score", color = NULL) +
theme_classic()
})
output$stud.plot4 = renderPlot({
ggplot(student_data(), aes(x = SESSION_NUMBER, y = ATTENDED)) +
geom_point(color = "#31a354", size = 2) +
scale_y_continuous(breaks = c(0, 1), labels = c("Absent", "Present")) +
labs(x = "Session Number", y = "Attendance") +
theme_classic()
})
#######################################
#######################################
}
#######################################
### This code creates the dashboard ###
#######################################
# Here we set up the Header of the dashboard
dhead = dashboardHeader(title = "Clicker Dashboard")
# Here set up the sidebar which has links to two pages
dside = dashboardSidebar(
sidebarMenu(
menuItem("Instructor View", tabName = "instructor", icon = icon("dashboard")),
menuItem("Student View", tabName = "student", icon = icon("th"))
)
)
# Here we set up the body of the dashboard
dbody = dashboardBody(
tabItems(
student_dash,
instructor_dash
)
)
# Combining header, sidebar, and body
ui = dashboardPage(dhead, dside, dbody)
# Generating a local instance of your dashboard
shinyApp(ui, server)
