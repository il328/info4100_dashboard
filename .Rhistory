# Replace this to input$student_id to update it dynamically.
target_student_id <- 101
all_sessions <- sort(unique(quiz$session_number))
attendance_data <- quiz %>%
filter(student_key == target_student_id) %>%
arrange(session_number) %>%
mutate(
session = factor(paste0("S", session_number), levels = paste0("S", all_sessions)),
status = ifelse(attended == 1, "attended", "absent"),
height = ifelse(status == "attended", 1.0, 0.5)
) %>%
select(session, status, height)
colnames(quiz)
